# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# YouTube Data API v3 key — https://console.cloud.google.com/apis/credentials
# (enable "YouTube Data API v3" for the project, then create an API key)
# Optional: without it the chat still works, video suggestions are just skipped.
YOUTUBE_API_KEY=

# Deployed frontend origin for CORS (no trailing slash), e.g. https://your-app.vercel.app
# Optional in local dev — localhost:5173 is always allowed.
FRONTEND_URL=
